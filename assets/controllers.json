{
    "controllers": {
        "@survos/api-grid-bundle": {
            "api_grid": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": {
                    "datatables.net-columncontrol-bs5/css/columnControl.bootstrap5.css": true,
                    "datatables.net-bs5/css/dataTables.bootstrap5.css": true,
                    "datatables.net-buttons-bs5/css/buttons.bootstrap5.css": true,
                    "datatables.net-responsive-bs5/css/responsive.bootstrap5.css": true,
                    "datatables.net-searchbuilder-bs5/css/searchBuilder.bootstrap5.css": true,
                    "datatables.net-select-bs5/css/select.bootstrap5.css": true
                }
            }
        },
        "@survos/iiif-bundle": {
            "iiif-viewer": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": []
            },
            "iiif-diva": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": []
            },
            "iiif-pdf": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": []
            }
        },
        "@survos/imgproxy-bundle": {
            "imgproxy": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": []
            }
        },
        "@survos/js-twig-bundle": {
            "dexie": {
                "enabled": true,
                "fetch": "eager",
                "autoimport": []
            },
            "js_twig": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": []
            }
        },
        "@survos/meili-bundle": {
            "insta": {
                "enabled": true,
                "fetch": "eager",
                "autoimport": {
                    "instantsearch.css/themes/algolia.min.css": false,
                    "pretty-print-json/dist/css/pretty-print-json.min.css": true
                }
            },
            "json": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": []
            },
            "chat": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": {
                    "@survos/meili/styles/chat.css": true
                }
            }
        },
        "@survos/simple-datatables-bundle": {
            "table": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": {
                    "@survos/simple-datatables/style.css": true
                }
            }
        },
        "@survos/state-bundle": {
            "workflow": {
                "enabled": true,
                "fetch": "eager"
            }
        },
        "@survos/tabler-bundle": {
            "accordion": {
                "enabled": true,
                "fetch": "lazy"
            },
            "search": {
                "enabled": true,
                "fetch": "lazy"
            }
        },
        "@survos/tree-bundle": {
            "tree": {
                "enabled": true,
                "fetch": "lazy"
            },
            "api_tree": {
                "enabled": true,
                "fetch": "lazy"
            }
        },
        "@symfony/ux-chartjs": {
            "chart": {
                "enabled": true,
                "fetch": "eager"
            }
        },
        "@symfony/ux-live-component": {
            "live": {
                "enabled": true,
                "fetch": "eager",
                "autoimport": {
                    "@symfony/ux-live-component/dist/live.min.css": true
                }
            }
        },
        "@tacman/ux-search": {
            "ux-search": {
                "enabled": true,
                "fetch": "eager",
                "autoimport": {
                    "@tacman/ux-search/dist/default.min.css": true
                }
            },
            "ux-search--refinement-list": {
                "enabled": true,
                "fetch": "eager"
            },
            "ux-search-range-slider": {
                "enabled": true,
                "fetch": "eager"
            }
        }
    },
    "entrypoints": []
}
