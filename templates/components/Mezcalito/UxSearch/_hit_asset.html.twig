{% set title = asset.aiTitle ?: asset.title ?: asset.filename ?: asset.id %}
{% set summary = asset.aiDescription ?: asset.description ?: asset.aiOcrText %}
{% set keywords = asset.aiKeywords|default([]) %}
{% if keywords is not iterable %}
    {% set keywords = [] %}
{% endif %}
{% set classifications = asset.classification|default([]) %}
{% if classifications is not iterable %}
    {% set classifications = [] %}
{% endif %}
{% set objectIdentifiers = asset.objectIdentifiers|default([]) %}
{% if objectIdentifiers is not iterable %}
    {% set objectIdentifiers = [] %}
{% endif %}

<article class="card h-100 asset-search-card">
    <a href="{{ path('asset_show', {id: asset.id}) }}" class="ratio ratio-4x3 bg-light d-flex align-items-center justify-content-center overflow-hidden">
        {# Render via imgproxy from the canonical master, not a stored derivative. #}
        {% set thumbSource = asset.storageKey
            ? 's3://museado/' ~ asset.storageKey
            : (asset.archiveUrl ?: asset.originalUrl)
        %}
        {% if thumbSource %}
            <img
                src="{{ thumbSource|imgproxy('thumb') }}"
                alt="{{ title }}"
                class="w-100 h-100 object-fit-contain"
                loading="lazy"
            >
        {% else %}
            <span class="text-muted small">No preview</span>
        {% endif %}
    </a>

    <div class="card-body d-flex flex-column gap-2">
        <div>
            <div class="fw-semibold text-break">{{ title }}</div>
            <div class="small text-muted font-monospace">{{ asset.id }}</div>
        </div>

        {# The most valuable automatic signal — classification + detected objects — up front. #}
        {% if classifications or objectIdentifiers %}
            <div class="d-flex flex-wrap gap-1">
                {% for classification in classifications|slice(0, 5) %}
                    <span class="badge bg-green-lt">{{ classification }}</span>
                {% endfor %}
                {% for objectIdentifier in objectIdentifiers|slice(0, 5) %}
                    <span class="badge bg-cyan-lt">{{ objectIdentifier }}</span>
                {% endfor %}
            </div>
        {% endif %}

        {% if summary %}
            <div class="small text-muted">{{ summary|u.truncate(180, '...') }}</div>
        {% endif %}

        {% if keywords %}
            <div class="d-flex flex-wrap gap-1">
                {% for keyword in keywords|slice(0, 6) %}
                    <span class="badge text-bg-light">{{ keyword }}</span>
                {% endfor %}
            </div>
        {% endif %}

        <div class="d-flex flex-wrap gap-1">
            <span class="badge bg-secondary-lt">{{ asset.marking }}</span>
            {% if asset.aiDocumentType %}
                <span class="badge bg-purple-lt">{{ asset.aiDocumentType }}</span>
            {% endif %}
        </div>

        {# mime demoted to the muted footer — much less important than the labels above. #}
        <div class="small text-muted mt-auto">
            {% if asset.width and asset.height %}{{ asset.width }} x {{ asset.height }}{% endif %}
            {% if asset.size %}<span class="ms-2">{{ asset.size|bytes }}</span>{% endif %}
            {% if asset.mime %}<span class="ms-2">{{ asset.mime }}</span>{% endif %}
        </div>
    </div>
</article>
