{% extends 'base.html.twig' %}

{% block title %}{{ asset.aiTitle ?? asset.id }}{% endblock %}

{% block body %}
<div class="container-xl py-4">

  {# ── Breadcrumb ──────────────────────────────────────────────────────────── #}
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="{{ path('asset_browse') }}">Assets</a></li>
      <li class="breadcrumb-item active">{{ asset.aiTitle ?? asset.id }}</li>
    </ol>
  </nav>

  <div class="row g-4">

    {# ── LEFT: image + core metadata ────────────────────────────────────────── #}
    <div class="col-lg-5">

      {#
      <div class="card mb-3">
        <div class="card-body">
          <div id="mirador" style="width: 100%; min-height: 512px;"></div>
        </div>
      </div>
      #}

      {# Image preview — IIIF viewer component #}
      {% set meta %}{{ asset.mime|default('unknown') }}{% if asset.width and asset.height %} · {{ asset.width }}×{{ asset.height }}{% endif %}{% if asset.size %} · {{ (asset.size / 1024)|round }}KB{% endif %}{% endset %}
      <div class="card mb-3">
        <div class="card-body p-0">
          {#
          <twig:iiif:viewer
            infoUrl="{{ path('iiif_image_info', {id: asset.id}) }}"
            manifestUrl="{{ path('iiif_manifest', {id: asset.id}) }}"
            miradorUrl="{{ path('iiif_mirador', {id: asset.id}) }}"
            uvUrl="{{ path('iiif_uv', {id: asset.id}) }}"
            meta="{{ meta }}"
          />
          #}
          <div id="openseadragon" style="width: 100%; min-height: 512px;"></div>
        </div>
        <div class="card-footer small text-muted">
          {{ path('iiif_image_info', {id: asset.id}) }}
          {{ path('iiif_manifest', {id: asset.id}) }}
          <a href="{{ asset.originalUrl }}" target="_blank" class="btn btn-xs btn-ghost-secondary">Original ↗</a>
        </div>
      </div>

      {# ── Source metadata from DC / aggregator context ────────────────────── #}
      {% set ctx = asset.context %}
      {% if ctx %}
        <div class="card mb-3">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="card-title mb-0">Source Metadata</h4>
            {% if ctx.aggregator is defined %}
              <span class="badge bg-blue-lt">{{ ctx.aggregator }}</span>
            {% endif %}
          </div>
          <div class="card-body small p-2">
            <table class="table table-sm table-borderless mb-0">

              {% macro row(label, value) %}
                {% if value %}
                  <tr>
                    <th class="text-muted fw-normal pe-3" style="width:30%;white-space:nowrap;">{{ label }}</th>
                    <td>{{ value }}</td>
                  </tr>
                {% endif %}
              {% endmacro %}

              {% macro rowBadges(label, values) %}
                {% if values %}
                  <tr>
                    <th class="text-muted fw-normal pe-3" style="width:30%;white-space:nowrap;">{{ label }}</th>
                    <td>
                      {% for v in values %}<span class="badge bg-secondary-lt me-1">{{ v }}</span>{% endfor %}
                    </td>
                  </tr>
                {% endif %}
              {% endmacro %}

              {{ _self.row('Title',       ctx['dcterms:title']|default(null)) }}
              {{ _self.row('Date',        ctx['dcterms:date']|default(null)) }}
              {{ _self.row('Type',        ctx['dcterms:type']|default(null)) }}
              {{ _self.row('Institution', ctx['dcterms:publisher']|default(null)) }}
              {{ _self.rowBadges('Creator',    ctx['dcterms:creator']|default([])) }}
              {{ _self.rowBadges('Subject',    ctx['dcterms:subject']|default([])) }}
              {{ _self.rowBadges('Collection', ctx['dcterms:isPartOf']|default([])) }}
              {{ _self.row('Rights',      ctx.rights|default(null)) }}
              {{ _self.row('License',     ctx.license_uri|default(null)) }}

              {% if ctx['dcterms:source'] is defined and ctx['dcterms:source'] %}
                <tr>
                  <th class="text-muted fw-normal pe-3">Source</th>
                  <td><a href="{{ ctx['dcterms:source'] }}" target="_blank" rel="noopener">{{ ctx['dcterms:source']|slice(0,60) }}{% if ctx['dcterms:source']|length > 60 %}…{% endif %}</a></td>
                </tr>
              {% endif %}

              {% if ctx.iiif_manifest is defined and ctx.iiif_manifest %}
                <tr>
                  <th class="text-muted fw-normal pe-3">IIIF Manifest</th>
                  <td>
                    <a href="{{ ctx.iiif_manifest }}" target="_blank" rel="noopener" class="btn btn-xs btn-outline-secondary">manifest ↗</a>
                  </td>
                </tr>
              {% endif %}

              {% if ctx.iiif_base is defined and ctx.iiif_base %}
                <tr>
                  <th class="text-muted fw-normal pe-3">Thumbnail</th>
                  <td>
                    <a href="{{ ctx.iiif_base }}/full/!200,200/0/default.jpg" target="_blank" rel="noopener">
                      <img src="{{ ctx.iiif_base }}/full/!200,200/0/default.jpg"
                           alt="thumbnail"
                           style="max-width:120px;max-height:120px;border-radius:4px;"
                           loading="lazy">
                    </a>
                    <div class="text-muted mt-1" style="font-size:0.65rem;word-break:break-all;">{{ ctx.iiif_base }}</div>
                  </td>
                </tr>
                <tr>
                  <th class="text-muted fw-normal pe-3">IIIF sizes</th>
                  <td class="d-flex gap-1 flex-wrap">
                    {% for label, size in {'thumb': '!200,200', 'small': '!400,400', 'medium': '!800,800', 'max': 'max'} %}
                      <a href="{{ ctx.iiif_base }}/full/{{ size }}/0/default.jpg"
                         target="_blank" rel="noopener"
                         class="btn btn-xs btn-ghost-secondary">{{ label }}</a>
                    {% endfor %}
                  </td>
                </tr>
              {% endif %}

              {% if ctx.source_ark is defined and ctx.source_ark %}
                <tr>
                  <th class="text-muted fw-normal pe-3">ARK</th>
                  <td><code>{{ ctx.source_ark }}</code></td>
                </tr>
              {% endif %}

            </table>
          </div>
        </div>
      {% endif %}

      {# Core AI fields #}
      <div class="card mb-3">
        <div class="card-header"><h4 class="card-title">AI Metadata</h4></div>
        <div class="card-body">

          {% if asset.aiTitle %}
            <div class="mb-2">
              <div class="small text-muted">Title</div>
              <div class="fw-semibold">{{ asset.aiTitle }}</div>
            </div>
          {% endif %}

          {% if asset.aiDocumentType %}
            <div class="mb-2">
              <div class="small text-muted">Type</div>
              <span class="badge bg-blue">{{ asset.aiDocumentType }}</span>
              {% if asset.aiDocumentSubtype %}
                <span class="badge bg-blue-lt ms-1">{{ asset.aiDocumentSubtype }}</span>
              {% endif %}
            </div>
          {% endif %}

          {% if asset.aiDateRange %}
            <div class="mb-2">
              <div class="small text-muted">Date</div>
              <div>{{ asset.aiDateRange }}</div>
            </div>
          {% endif %}

          {% if asset.aiDescription %}
            <div class="mb-2">
              <div class="small text-muted">Description</div>
              <div class="small">{{ asset.aiDescription }}</div>
            </div>
          {% endif %}

          {% if asset.aiSummary %}
            <div class="mb-2">
              <div class="small text-muted">Summary</div>
              <div class="small">{{ asset.aiSummary }}</div>
            </div>
          {% endif %}

          {% if asset.aiPeople|length > 0 %}
            <div class="mb-2">
              <div class="small text-muted">People</div>
              <div>{% for p in asset.aiPeople %}<span class="badge bg-cyan-lt me-1">{{ p }}</span>{% endfor %}</div>
            </div>
          {% endif %}

          {% if asset.aiPlaces|length > 0 %}
            <div class="mb-2">
              <div class="small text-muted">Places</div>
              <div>{% for p in asset.aiPlaces %}<span class="badge bg-green-lt me-1">{{ p }}</span>{% endfor %}</div>
            </div>
          {% endif %}

          {% if asset.aiOrganisations|length > 0 %}
            <div class="mb-2">
              <div class="small text-muted">Organisations</div>
              <div>{% for o in asset.aiOrganisations %}<span class="badge bg-purple-lt me-1">{{ o }}</span>{% endfor %}</div>
            </div>
          {% endif %}

          {% if asset.aiKeywords|length > 0 %}
            <div class="mb-2">
              <div class="small text-muted">Keywords</div>
              <div class="small">{% for k in asset.aiKeywords %}<span class="badge bg-secondary-lt me-1 mb-1">{{ k }}</span>{% endfor %}</div>
            </div>
          {% endif %}

          {% if asset.aiOcrText %}
            <div class="mb-2">
              <div class="small text-muted">OCR Text <span class="text-muted">(excerpt)</span></div>
              <pre class="small bg-light p-2 rounded" style="max-height:120px;overflow-y:auto;white-space:pre-wrap;">{{ asset.aiOcrText|slice(0,500) }}{% if asset.aiOcrText|length > 500 %}…{% endif %}</pre>
            </div>
          {% endif %}

          {% if not (asset.aiTitle or asset.aiDescription or asset.aiDocumentType) %}
            <div class="text-muted small">No AI metadata yet — run tasks below.</div>
          {% endif %}

        </div>
      </div>

      {# Technical details #}
      <div class="card mb-3">
        <div class="card-header">
          <h4 class="card-title">Technical</h4>
          <div class="card-options">
            <span class="badge bg-{{ asset.marking == 'complete' ? 'green' : (asset.marking == 'failed' ? 'red' : (asset.marking == 'ai_ready' ? 'yellow' : 'secondary')) }}">
              {{ asset.marking }}
            </span>
          </div>
        </div>
        <div class="card-body small p-2">
          <table class="table table-sm table-borderless mb-0">
            <tr><th>ID</th><td><code>{{ asset.id }}</code></td></tr>
            <tr><th>MIME</th><td>{{ asset.mime|default('—') }}</td></tr>
            <tr><th>Created</th><td>{{ asset.createdAt|date('Y-m-d H:i') }}</td></tr>
            {% if asset.clients %}
            <tr><th>Clients</th><td>{{ asset.clients|join(', ') }}</td></tr>
            {% endif %}
            <tr><th>AI Locked</th>
              <td>
                <form method="post" action="{{ path('asset_toggle_lock', {id: asset.id}) }}" class="d-inline">
                  <button class="btn btn-xs {{ asset.aiLocked ? 'btn-warning' : 'btn-ghost-secondary' }}">
                    {{ asset.aiLocked ? '🔒 Locked' : '🔓 Unlocked' }}
                  </button>
                </form>
              </td>
            </tr>
          </table>
        </div>
      </div>

    </div>{# /col-lg-5 #}

    {# ── RIGHT: AI task runner ───────────────────────────────────────────────── #}
    <div class="col-lg-7">

      {# Pipeline shortcuts #}
      <div class="card mb-3">
        <div class="card-header">
          <h4 class="card-title">Pipelines</h4>
        </div>
        <div class="card-body d-flex gap-2 flex-wrap">
          {% for pipelineName, pipelineTasks in pipelines %}
            <form method="post" action="{{ path('asset_enqueue_pipeline', {id: asset.id, name: pipelineName}) }}">
              <button class="btn btn-sm btn-outline-primary">
                ▶ {{ pipelineName|capitalize }} pipeline
                <span class="badge bg-primary-lt ms-1">{{ pipelineTasks|length }}</span>
              </button>
            </form>
          {% endfor %}
          <a href="{{ path('asset_task_registry') }}" class="btn btn-sm btn-ghost-secondary">
            View task registry →
          </a>
        </div>
        {% if asset.aiQueue|length > 0 %}
          <div class="card-footer small text-muted">
            Queue: {{ asset.aiQueue|join(' → ') }}
          </div>
        {% endif %}
      </div>

      {# Individual task buttons #}
      <div class="card mb-3">
        <div class="card-header">
          <h4 class="card-title">Run Individual Task</h4>
          <div class="card-options text-muted small">results appear in the log below</div>
        </div>
        <div class="card-body">
          {#
            hx-sync="this:queue" on the grid means HTMX will queue requests
            from any button — they run one at a time, in the order clicked.
          #}
          <div class="row g-2" id="task-grid" hx-sync="this:queue sequential">
            {% for task in tasks %}
              {% set isDone = completedMap[task] is defined %}
              {% set hasFailed = isDone and (completedMap[task].result.failed is defined) %}
              {% set meta = taskMeta[task] ?? {} %}
              {% set popContent %}agent: {{ meta.agent|default('?') }}
model: {{ meta.model|default('—') }}
platform: {{ meta.platform|default('—') }}

{{ meta.system_prompt|default('no prompt info')|slice(0, 400) }}{% if (meta.system_prompt|default(''))|length > 400 %}…{% endif %}{% endset %}
              <div class="col-sm-6" id="task-card-col-{{ task }}">
                {{ include('asset/_task_card.html.twig', {
                  task: task,
                  isDone: isDone,
                  hasFailed: hasFailed,
                  entry: completedMap[task] ?? null,
                  meta: meta,
                  popContent: popContent,
                  assetId: asset.id,
                }, with_context: false) }}
              </div>
            {% endfor %}
          </div>
        </div>
      </div>

      {# ── Task log — new results prepended here by HTMX ─────────────────────── #}
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h4 class="card-title mb-0">Results Log</h4>
          {% if asset.aiCompleted|length > 0 %}
            <span class="badge bg-secondary">{{ asset.aiCompleted|length }} completed</span>
          {% endif %}
        </div>
        <div class="card-body p-2" id="task-log">
          {% if asset.aiCompleted|length == 0 %}
            <div class="text-muted small p-2" id="log-empty">No tasks run yet — click a button above.</div>
          {% else %}
            {% for entry in asset.aiCompleted|reverse %}
              {{ include('asset/_task_result_log.html.twig', {entry: entry}, with_context: false) }}
            {% endfor %}
          {% endif %}
        </div>
      </div>

    </div>{# /col-lg-7 #}
  </div>{# /row #}
</div>
{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    /* HTMX request in flight: show spinner, hide the arrow label.
       htmx-request is added to the element with hx-post (the <form>),
       but with hx-sync on a parent HTMX 2 may add it to the grid div too.
       Cover both cases. */
    .htmx-indicator                          { display: none; }
    .htmx-request .htmx-indicator,
    .htmx-request.htmx-indicator             { display: inline-block !important; }
    .htmx-request .htmx-indicator-hide,
    .htmx-request.htmx-indicator-hide        { display: none !important; }
    .htmx-request button                     { pointer-events: none; opacity: 0.75; }

    /* Hide the "no tasks run yet" placeholder once real entries exist */
    #task-log #log-empty:not(:only-child)    { display: none !important; }

    /* Task info popover — monospace prompt text, reasonable width */
    .task-popover .popover-body {
      font-family: var(--tblr-font-monospace, monospace);
      font-size: 0.72rem;
      white-space: pre-wrap;
      max-width: 360px;
      color: #333;
    }
    .popover { max-width: 380px; }

    .openseadragon-container {
      height: 512px !important;
    }

    .iiif-annotation {
      box-sizing: border-box;
      transition: background 0.15s;
    }
    .iiif-annotation:hover {
      background: rgba(255, 100, 0, 0.25) !important;
    }
  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script type="module">
    import 'htmx.org';
    import { Popover } from 'bootstrap';

    document.querySelectorAll('[data-bs-toggle="popover"]').forEach(el => {
      new Popover(el, { html: false });
    });

    /*
    const miradorInstance = Mirador.viewer({
      id: "mirador",
      windows: [
        {
          loadedManifest: "https://api.digitale-sammlungen.de/iiif/presentation/v2/bsb12024369/manifest", // Example manifest
        }
      ],
      window: {
        defaultSideBarPanel: "info", // Shows metadata by default
      },
      workspace: {
        showZoomControls: true
      }
    });
    */

    {# why are we doing this and not our stimulus controller? #}
    const osd = OpenSeadragon({
      id: 'openseadragon',
      prefixUrl: 'https://cdn.jsdelivr.net/npm/openseadragon@6.0.1/build/openseadragon/images/',
      crossOriginPolicy: false,
      tileSources: [{
        manifest: '{{ path("iiif_manifest", {id: asset.id}) }}',
        tileSource: '{{ path("iiif_image_info", {id: asset.id})|raw }}'
      }],
    });

    osd.addHandler('open', async function() {
  const manifestUrl = '{{ path("iiif_manifest", {id: asset.id})|raw }}';
  const manifest = await fetch(manifestUrl).then(r => r.json());

  const annotationPages = manifest.items?.[0]?.annotations ?? [];

  for (const pageRef of annotationPages) {
    const page = await fetch(pageRef.id).then(r => r.json());
    console.log('annotations loaded:', page.items);

    // Render each annotation as an OSD overlay
    for (const annotation of page.items) {
      const target = annotation.target;

      // Handle xywh fragment e.g. canvas#xywh=100,200,300,400
      const match = typeof target === 'string' && target.match(/#xywh=(\d+),(\d+),(\d+),(\d+)/);
      if (match) {
        const [, x, y, w, h] = match.map(Number);
        const canvasW = manifest.items[0].width;
        const canvasH = manifest.items[0].height;

        // Convert canvas pixel coords to OSD viewport coords (0-1)
        const rect = osd.viewport.imageToViewportRectangle(x, y, w, h);

        const el = document.createElement('div');
        el.className = 'iiif-annotation';
        el.title = annotation.body?.value ?? '';
        el.style.cssText = 'border: 2px solid rgba(255,100,0,0.8); background: rgba(255,100,0,0.1); pointer-events: auto; cursor: pointer;';

        el.addEventListener('click', () => {
          console.log('annotation clicked:', annotation);
        });

        osd.addOverlay({ element: el, location: rect });
      }
    }
  }
});

    osd.addHandler('open-failed', function(event) {
      console.error('open-failed message:', event.message);
      console.error('open-failed source:', event.source);
    });
  </script>
{% endblock %}
