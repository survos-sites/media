{% extends 'base.html.twig' %}

{% block title %}{{ asset.aiTitle ?? asset.id }}{% endblock %}
{% set iiifParam = app.request.query.get('iiif')|default(false) %}
{% set useIiif = iiifParam in ['1', 'true', 'yes', 'on'] %}
{% set zoomImageUrl = asset.originalUrl ?? computedArchiveUrl ?? asset.archiveUrl ?? asset.smallUrl %}
{% set zoomFallbackUrl = computedArchiveUrl ?? asset.archiveUrl ?? asset.smallUrl ?? null %}
{% set enrichment = asset.mediaEnrichmentDto %}
{% set taskResults = asset.aiCompleted|default([]) %}
{% if taskResults is empty and asset.context is defined and asset.context.aiTaskResults is defined and asset.context.aiTaskResults is iterable %}
  {% set taskResults = asset.context.aiTaskResults %}
{% endif %}
{% set enrichEntry = null %}
{% for entry in taskResults|reverse %}
  {% if enrichEntry is null and entry.task|default('') == 'enrich_from_thumbnail' %}
    {% set enrichEntry = entry %}
  {% endif %}
{% endfor %}
{% set humanTitle = asset.sourceMeta['dcterms:title']|default(asset.sourceMeta.title|default(asset.title|default(null))) %}
{% set humanDescription = asset.sourceMeta['dcterms:description']|default(asset.sourceMeta.description|default(asset.description|default(null))) %}
{% set enrichLowResRun = null %}
{% set enrichHighResRun = null %}
{% set mistralHighResRun = null %}
{% for entry in taskResults|reverse %}
  {% set taskName = entry.task|default('') %}
  {% set result = entry.result|default({}) %}
  {% set dbg = result._debug|default({}) %}
  {% set source = dbg.image_source|default('') %}
  {% set modelName = (dbg.requested_model|default(dbg.meta.model|default('')))|lower %}
  {% set isLowRes = source and ('thumb' in source or 'small' in source or 'source_meta' in source) %}
  {% set isHighRes = source and ('full' in source or source in ['archive_url', 'original_url']) %}
  {% if taskName == 'enrich_from_thumbnail' %}
    {% if enrichLowResRun is null and isLowRes %}
      {% set enrichLowResRun = entry %}
    {% endif %}
    {% if enrichHighResRun is null and isHighRes %}
      {% set enrichHighResRun = entry %}
    {% endif %}
  {% endif %}
  {% if mistralHighResRun is null and isHighRes and ('mistral' in modelName) %}
    {% set mistralHighResRun = entry %}
  {% endif %}
{% endfor %}

{% block body %}
<div class="container-xl py-4">

  {# ── Breadcrumb ──────────────────────────────────────────────────────────── #}
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="{{ path('asset_browse') }}">Assets</a></li>
      <li class="breadcrumb-item active">{{ asset.aiTitle ?? asset.id }}</li>
    </ol>
  </nav>

  <div class="row g-4">

    {# ── LEFT: image + core metadata ────────────────────────────────────────── #}
    <div class="col-lg-5">

      {# Image preview — IIIF viewer component #}
      {% set meta %}{{ asset.mime|default('unknown') }}{% if asset.width and asset.height %} · {{ asset.width }}×{{ asset.height }}{% endif %}{% if asset.size %} · {{ (asset.size / 1024)|round }}KB{% endif %}{% endset %}
      <div class="card mb-3">
        <div class="card-header">
          <h4 class="card-title mb-0">
            {% if useIiif %} IIIF Viewer {% else %} Image Preview {% endif %}
          </h4>
        </div>
        <div class="card-body p-0">
          {% if useIiif %}
            <twig:iiif:viewer
              manifestUrl="{{ path('iiif_manifest', {id: asset.id}) }}"
              tileSourceUrl="{{ path('iiif_image_info', {id: asset.id}) }}"
              options="{{ {

              } | json_encode(constant('JSON_FORCE_OBJECT')) }}"
              style=""
              meta="{{ meta }}"
              miradorUrl="{{ path('iiif_mirador', {id: asset.id}) }}"
              uvUrl="{{ path('iiif_uv', {id: asset.id}) }}"
              showLinks="{{ true }}"
            />
          {% else %}
            <div class="simple-zoom-wrap" id="simple-zoom-wrap">
              <img
                id="simple-zoom-image"
                src="{{ zoomImageUrl }}"
                {% if zoomFallbackUrl %}data-fallback-src="{{ zoomFallbackUrl }}"{% endif %}
                alt="Asset preview"
                class="simple-zoom-image"
                loading="eager"
              >
            </div>
          {% endif %}
        </div>
        <div class="card-footer small text-muted">
          {% if useIiif %}
            {{ path('iiif_image_info', {id: asset.id}) }}
            {{ path('iiif_manifest', {id: asset.id}) }}
            <a href="{{ path('asset_show', {id: asset.id}) }}" class="btn btn-xs btn-outline-secondary ms-1">Simple zoom</a>
          {% else %}
            <span>Simple zoom mode</span>
            <a href="{{ path('asset_show', {id: asset.id, iiif: 'true'}) }}" class="btn btn-xs btn-outline-secondary ms-1">Try IIIF mode</a>
          {% endif %}
          <a href="{{ asset.originalUrl }}" target="_blank" class="btn btn-xs btn-ghost-secondary">Original ↗</a>
        </div>
      </div>

      {# Technical details #}
      <div class="card mb-3">
        <div class="card-header">
          <h4 class="card-title">Technical</h4>
          <div class="card-options">
            <span class="badge bg-{{ asset.marking == 'complete' ? 'green' : (asset.marking == 'failed' ? 'red' : (asset.marking == 'ai_ready' ? 'yellow' : 'secondary')) }}">
              {{ asset.marking }}
            </span>
          </div>
        </div>
        <div class="card-body small p-2">
          <table class="table table-sm table-borderless mb-0">
            <tr><th>ID</th><td><code>{{ asset.id }}</code></td></tr>
            <tr><th>MIME</th><td>{{ asset.mime|default('—') }}</td></tr>
            <tr><th>Created</th><td>{{ asset.createdAt|date('Y-m-d H:i') }}</td></tr>
            {% if asset.storageKey %}
            <tr><th>Storage Key</th><td><code class="small">{{ asset.storageKey }}</code></td></tr>
            {% endif %}
            {% if computedArchiveUrl %}
            <tr>
              <th>S3 URL (computed)</th>
              <td>
                <a href="{{ computedArchiveUrl }}" target="_blank" rel="noopener" class="btn btn-xs btn-outline-secondary">Open S3 ↗</a>
                <div class="text-muted mt-1" style="font-size:0.65rem;word-break:break-all;">{{ computedArchiveUrl }}</div>
              </td>
            </tr>
            {% endif %}
            {% if asset.archiveUrl %}
            <tr>
              <th>S3 URL (stored)</th>
              <td>
                <a href="{{ asset.archiveUrl }}" target="_blank" rel="noopener" class="btn btn-xs btn-ghost-secondary">Open stored ↗</a>
                {% if computedArchiveUrl and computedArchiveUrl != asset.archiveUrl %}
                  <span class="badge bg-red-lt ms-2">stale</span>
                {% endif %}
                <div class="text-muted mt-1" style="font-size:0.65rem;word-break:break-all;">{{ asset.archiveUrl }}</div>
              </td>
            </tr>
            {% endif %}
            {% if asset.clients %}
            <tr><th>Clients</th><td>{{ asset.clients|join(', ') }}</td></tr>
            {% endif %}
            <tr><th>AI Locked</th>
              <td>
                <form method="post" action="{{ path('asset_toggle_lock', {id: asset.id}) }}" class="d-inline">
                  <button class="btn btn-xs {{ asset.aiLocked ? 'btn-warning' : 'btn-ghost-secondary' }}">
                    {{ asset.aiLocked ? '🔒 Locked' : '🔓 Unlocked' }}
                  </button>
                </form>
              </td>
            </tr>
          </table>
        </div>
      </div>

    </div>{# /col-lg-5 #}

    {# ── RIGHT: AI task runner ───────────────────────────────────────────────── #}
    <div class="col-lg-7">

      {% set tabId = 'asset-' ~ asset.id %}

      <div class="card mb-3">
        <div class="card-header">
          <ul class="nav nav-tabs card-header-tabs" id="{{ tabId }}-nav" data-bs-toggle="tabs" role="tablist">
            <li class="nav-item"><a href="#{{ tabId }}-ocr"              class="nav-link active" data-bs-toggle="tab" data-tab-id="ocr">OCR</a></li>
            <li class="nav-item"><a href="#{{ tabId }}-source_metadata"  class="nav-link" data-bs-toggle="tab" data-tab-id="source_metadata">Source Metadata</a></li>
            <li class="nav-item"><a href="#{{ tabId }}-edge_analysis"    class="nav-link" data-bs-toggle="tab" data-tab-id="edge_analysis">Edge Analysis</a></li>
            <li class="nav-item"><a href="#{{ tabId }}-ai_metadata"      class="nav-link" data-bs-toggle="tab" data-tab-id="ai_metadata">AI Metadata</a></li>
            <li class="nav-item"><a href="#{{ tabId }}-ai_task_results"  class="nav-link" data-bs-toggle="tab" data-tab-id="ai_task_results">AI Task Results</a></li>
            <li class="nav-item"><a href="#{{ tabId }}-media_enrichment" class="nav-link" data-bs-toggle="tab" data-tab-id="media_enrichment">Media Enrichment</a></li>
            <li class="nav-item"><a href="#{{ tabId }}-human_vs_ai"      class="nav-link" data-bs-toggle="tab" data-tab-id="human_vs_ai">Human vs AI</a></li>
            <li class="nav-item"><a href="#{{ tabId }}-tasks"            class="nav-link" data-bs-toggle="tab" data-tab-id="tasks">Tasks</a></li>
            {% if app.debug %}
            <li class="nav-item"><a href="#{{ tabId }}-dev_dump"         class="nav-link" data-bs-toggle="tab" data-tab-id="dev_dump">Dev Dump</a></li>
            {% endif %}
          </ul>
        </div>
        <div class="card-body">
          <div class="tab-content">

        {# ── OCR ──────────────────────────────────────────────────────────────── #}
        <div id="{{ tabId }}-ocr" class="tab-pane active show" role="tabpanel">
          <twig:AiMetadata :results="asset.aiResults()" group="ocr" />
        </div>
        {# ── Source Metadata ──────────────────────────────────────────────────── #}
        <div id="{{ tabId }}-source_metadata" class="tab-pane" role="tabpanel">
          {% set ctx = asset.sourceMeta %}
          {% if ctx %}
            <div class="card">
              <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0">Source Metadata</h4>
                {% if ctx.aggregator is defined %}
                  <span class="badge bg-blue-lt">{{ ctx.aggregator }}</span>
                {% endif %}
              </div>
              <div class="card-body small p-2">
                <twig:SourceMetadata :ctx="asset.sourceMeta ?? {}" />
                {% if ctx['dcterms:source'] is defined and ctx['dcterms:source'] %}
                  <tr>
                    <th class="text-muted fw-normal pe-3">Source</th>
                    <td><a href="{{ ctx['dcterms:source'] }}" target="_blank" rel="noopener">{{ ctx['dcterms:source']|slice(0,60) }}{% if ctx['dcterms:source']|length > 60 %}…{% endif %}</a></td>
                  </tr>
                {% endif %}
                {% if ctx.iiif_manifest is defined and ctx.iiif_manifest %}
                  <tr>
                    <th class="text-muted fw-normal pe-3">IIIF Manifest</th>
                    <td><a href="{{ ctx.iiif_manifest }}" target="_blank" rel="noopener" class="btn btn-xs btn-outline-secondary">manifest ↗</a></td>
                  </tr>
                {% endif %}
                {% if ctx.iiif_base is defined and ctx.iiif_base %}
                  <tr>
                    <th class="text-muted fw-normal pe-3">Thumbnail</th>
                    <td>
                      <a href="{{ ctx.iiif_base }}/full/!200,200/0/default.jpg" target="_blank" rel="noopener">
                        <img src="{{ ctx.iiif_base }}/full/!200,200/0/default.jpg" alt="thumbnail" style="max-width:120px;max-height:120px;border-radius:4px;" loading="lazy">
                      </a>
                      <div class="text-muted mt-1" style="font-size:0.65rem;word-break:break-all;">{{ ctx.iiif_base }}</div>
                    </td>
                  </tr>
                  <tr>
                    <th class="text-muted fw-normal pe-3">IIIF sizes</th>
                    <td class="d-flex gap-1 flex-wrap">
                      {% for label, size in {'thumb': '!200,200', 'small': '!400,400', 'medium': '!800,800', 'max': 'max'} %}
                        <a href="{{ ctx.iiif_base }}/full/{{ size }}/0/default.jpg" target="_blank" rel="noopener" class="btn btn-xs btn-ghost-secondary">{{ label }}</a>
                      {% endfor %}
                    </td>
                  </tr>
                {% endif %}
                {% if ctx.source_ark is defined and ctx.source_ark %}
                  <tr>
                    <th class="text-muted fw-normal pe-3">ARK</th>
                    <td><code>{{ ctx.source_ark }}</code></td>
                  </tr>
                {% endif %}
              </div>
            </div>
          {% endif %}
        </div>

        {# ── Edge Analysis ────────────────────────────────────────────────────── #}
        <div id="{{ tabId }}-edge_analysis" class="tab-pane" role="tabpanel">
          {% set edge = asset.context.edge_analysis|default(null) %}
          {% if edge %}
            <div class="card">
              <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0">Type and OCR Gate</h4>
                {% if edge.primary_type|default(null) %}
                  <span class="badge bg-azure-lt">{{ edge.primary_type }}</span>
                {% endif %}
              </div>
              <div class="card-body small p-2">
                <table class="table table-sm table-borderless mb-3">
                  <tr><th>Type Estimate</th><td>{{ asset.context.type_estimate|default('—') }}</td></tr>
                  <tr><th>Has Text Likely</th><td>{{ edge.has_text_likely ? 'yes' : 'no' }}</td></tr>
                  <tr><th>Typed Likely</th><td>{{ edge.typed_likely ? 'yes' : 'no' }}</td></tr>
                  <tr><th>Handwritten Likely</th><td>{{ edge.handwritten_likely ? 'yes' : 'no' }}</td></tr>
                  <tr><th>OCR Auto Queued</th><td>{{ asset.context.ocr_auto_queued|default(false) ? 'yes' : 'no' }}</td></tr>
                  <tr><th>Document Likely</th><td>{{ edge.document_likely|default(false) ? 'yes' : 'no' }}</td></tr>
                  <tr><th>Photo Likely</th><td>{{ edge.photo_likely|default(false) ? 'yes' : 'no' }}</td></tr>
                  <tr><th>People Likely</th><td>{{ edge.people_likely|default(false) ? 'yes' : 'no' }}</td></tr>
                  <tr><th>Tag Like</th><td>{{ edge.tag_like|default(false) ? 'yes' : 'no' }}</td></tr>
                </table>

                {% if edge.type_candidates|default([]) is not empty %}
                  <div class="mb-3">
                    <div class="text-muted fw-semibold mb-2">Type Candidates</div>
                    <div class="vstack gap-2">
                      {% for candidate in edge.type_candidates|slice(0,5) %}
                        <div class="border rounded p-2">
                          <div class="d-flex justify-content-between align-items-center">
                            <strong>{{ candidate.label|default('unknown') }}</strong>
                            <span class="badge bg-secondary-lt">score {{ candidate.score|default(0) }}</span>
                          </div>
                          {% if candidate.reasons|default([]) is not empty %}
                            <div class="small text-muted mt-1">{{ candidate.reasons|join('; ') }}</div>
                          {% endif %}
                        </div>
                      {% endfor %}
                    </div>
                  </div>
                {% endif %}

                {% if edge.reasons|default([]) is not empty %}
                  <div class="mb-3">
                    <div class="text-muted fw-semibold mb-2">Reasons</div>
                    <div class="small">{{ edge.reasons|join('; ') }}</div>
                  </div>
                {% endif %}

                <details>
                  <summary class="text-muted">Raw edge analysis</summary>
                  <pre class="small mb-0 mt-2">{{ edge|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
                </details>
              </div>
            </div>
          {% else %}
            <div class="text-muted small">No edge analysis recorded yet.</div>
          {% endif %}
        </div>

        {# ── AI Metadata ──────────────────────────────────────────────────────── #}
        <div id="{{ tabId }}-ai_metadata" class="tab-pane" role="tabpanel">
          <twig:AiMetadata :results="asset.aiResults()" group="image" />
        </div>

        {# ── AI Task Results ──────────────────────────────────────────────────── #}
        <div id="{{ tabId }}-ai_task_results" class="tab-pane" role="tabpanel">
          <div class="vstack gap-2" id="task-log">
            {% if taskResults|length == 0 %}
              <div class="text-muted small" id="log-empty">No task results yet.</div>
            {% else %}
              {% for entry in taskResults|reverse %}
                <div class="border rounded p-2">
                  <div class="d-flex justify-content-between align-items-center">
                    <strong>{{ entry.task }}</strong>
                    <small class="text-muted">{{ entry.at|default('') }}</small>
                  </div>
                  {% set debug = entry.result._debug|default(null) %}
                  {% if debug %}
                    <div class="small text-muted mt-1">
                      image: {{ debug.image_source|default('unknown') }}
                      {% if debug.meta is defined and debug.meta.model is defined and debug.meta.model %}· model: {{ debug.meta.model }}{% endif %}
                      {% if entry.result._tokens is defined and entry.result._tokens.total is defined %}· tokens: {{ entry.result._tokens.total }}{% endif %}
                      {% if debug.image_url is defined and debug.image_url %}· <a href="{{ debug.image_url }}" target="_blank" rel="noopener">open</a>{% endif %}
                    </div>
                  {% endif %}
                  <pre class="small mb-0 mt-2" style="white-space: pre-wrap;">{{ entry.result|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
                </div>
              {% endfor %}
            {% endif %}
          </div>
        </div>

        {# ── Media Enrichment ─────────────────────────────────────────────────── #}
        <div id="{{ tabId }}-media_enrichment" class="tab-pane" role="tabpanel">
          {% if enrichment is null %}
            <div class="text-muted small">No normalized media enrichment yet. Run AI tasks first.</div>
          {% else %}
            <table class="table table-sm">
              <tr><th style="width: 220px">Title</th><td>{{ enrichment.title ?? '—' }}</td></tr>
              <tr><th>Description</th><td>{{ enrichment.description ?? '—' }}</td></tr>
              <tr><th>Document Type</th><td>{{ enrichment.documentType ?? '—' }}{% if enrichment.documentSubtype %} / {{ enrichment.documentSubtype }}{% endif %}</td></tr>
              <tr><th>Keywords</th><td>{{ enrichment.keywords is not empty ? enrichment.keywords|join(', ') : '—' }}</td></tr>
              <tr><th>People</th><td>{{ enrichment.people is not empty ? enrichment.people|join(', ') : '—' }}</td></tr>
              <tr><th>Places</th><td>{{ enrichment.places is not empty ? enrichment.places|join(', ') : '—' }}</td></tr>
              <tr><th>OCR Text</th><td>{{ enrichment.ocrText ?? '—' }}</td></tr>
              <tr><th>Summary</th><td>{{ enrichment.summary ?? enrichment.denseSummary ?? '—' }}</td></tr>
              <tr><th>Image Source</th><td>{{ enrichment.imageSource ?? '—' }}</td></tr>
              <tr><th>Image URL</th><td>{% if enrichment.imageUrl %}<a href="{{ enrichment.imageUrl }}" target="_blank" rel="noopener">{{ enrichment.imageUrl }}</a>{% else %}—{% endif %}</td></tr>
            </table>
            <details class="mt-2">
              <summary class="small text-muted">Raw mediaEnrichment JSON</summary>
              <pre class="small mt-2" style="white-space: pre-wrap;">{{ enrichment.toArray()|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
            </details>
          {% endif %}
        </div>

        {# ── Human vs AI ──────────────────────────────────────────────────────── #}
        <div id="{{ tabId }}-human_vs_ai" class="tab-pane" role="tabpanel">
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <div class="card h-100">
                <div class="card-header"><h4 class="card-title mb-0">Human Metadata</h4></div>
                <div class="card-body small">
                  <div class="mb-2"><span class="text-muted">Title</span><div class="fw-semibold">{{ humanTitle ?? '—' }}</div></div>
                  <div><span class="text-muted">Description</span><div>{{ humanDescription ?? '—' }}</div></div>
                </div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="card h-100">
                <div class="card-header"><h4 class="card-title mb-0">AI Result</h4></div>
                <div class="card-body small">
                  <div class="mb-2"><span class="text-muted">Title</span><div class="fw-semibold">{{ enrichment ? (enrichment.title ?? '—') : '—' }}</div></div>
                  <div><span class="text-muted">Description</span><div>{{ enrichment ? (enrichment.description ?? '—') : '—' }}</div></div>
                  <hr class="my-2">
                  {% set firstPassSource = enrichEntry.result._debug.image_source|default(enrichment ? enrichment.imageSource : null) %}
                  <div>
                    <span class="text-muted">First-pass image source</span>
                    <div>
                      <span class="badge {{ firstPassSource and ('thumb' in firstPassSource or 'small' in firstPassSource or 'source_meta' in firstPassSource) ? 'bg-yellow-lt' : 'bg-secondary-lt' }}">{{ firstPassSource ?? 'unknown' }}</span>
                      {% if firstPassSource and ('thumb' in firstPassSource or 'small' in firstPassSource or 'source_meta' in firstPassSource) %}
                        <span class="text-muted ms-1">thumbnail / low-res pass</span>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h4 class="card-title mb-0">A/B: Enrichment Quality</h4>
              <span class="text-muted small">Low-res first pass vs high-res pass</span>
            </div>
            <div class="card-body">
              <div class="row g-3">
                <div class="col-md-6">
                  <div class="border rounded p-2 h-100">
                    <div class="fw-semibold mb-1">Low-res run</div>
                    {% if enrichLowResRun %}
                      {% set rr = enrichLowResRun.result|default({}) %}
                      {% set dd = rr._debug|default({}) %}
                      <div class="small text-muted mb-1">{{ dd.image_source|default('unknown') }} · {{ dd.meta.model|default('—') }} · {{ rr._tokens.total|default(0) }} tokens</div>
                      <div><span class="text-muted">Title:</span> <strong>{{ rr.title|default('—') }}</strong></div>
                      <div class="mt-1"><span class="text-muted">Description:</span> {{ rr.description|default('—') }}</div>
                    {% else %}
                      <div class="text-muted small">No low-res enrichment run found.</div>
                    {% endif %}
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="border rounded p-2 h-100">
                    <div class="fw-semibold mb-1">High-res run</div>
                    {% if enrichHighResRun %}
                      {% set rr = enrichHighResRun.result|default({}) %}
                      {% set dd = rr._debug|default({}) %}
                      <div class="small text-muted mb-1">{{ dd.image_source|default('unknown') }} · {{ dd.meta.model|default('—') }} · {{ rr._tokens.total|default(0) }} tokens</div>
                      <div><span class="text-muted">Title:</span> <strong>{{ rr.title|default('—') }}</strong></div>
                      <div class="mt-1"><span class="text-muted">Description:</span> {{ rr.description|default('—') }}</div>
                    {% else %}
                      <div class="text-muted small">No high-res enrichment run found yet.</div>
                    {% endif %}
                  </div>
                </div>
              </div>
              {% if humanTitle %}
                <div class="mt-3 small">
                  <span class="text-muted">Reference title:</span> <strong>{{ humanTitle }}</strong>
                  {% set lowTitle = enrichLowResRun ? (enrichLowResRun.result.title|default('')) : '' %}
                  {% set highTitle = enrichHighResRun ? (enrichHighResRun.result.title|default('')) : '' %}
                  {% if lowTitle %}<span class="ms-2 badge {{ lowTitle|lower == humanTitle|lower ? 'bg-green-lt' : 'bg-red-lt' }}">low-res {{ lowTitle|lower == humanTitle|lower ? 'match' : 'mismatch' }}</span>{% endif %}
                  {% if highTitle %}<span class="ms-1 badge {{ highTitle|lower == humanTitle|lower ? 'bg-green-lt' : 'bg-red-lt' }}">high-res {{ highTitle|lower == humanTitle|lower ? 'match' : 'mismatch' }}</span>{% endif %}
                </div>
              {% endif %}
            </div>
          </div>

          <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h4 class="card-title mb-0">Cost + Model Trace</h4>
              <span class="badge bg-secondary">{{ asset.aiTokensTotal }} tokens total</span>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-sm mb-0">
                  <thead><tr><th>Task</th><th>Model</th><th>Image Source</th><th class="text-end">Tokens</th></tr></thead>
                  <tbody>
                  {% for entry in taskResults|reverse %}
                    {% set r = entry.result|default({}) %}
                    {% set dbg = r._debug|default({}) %}
                    <tr>
                      <td><code>{{ entry.task|default('unknown') }}</code></td>
                      <td>{{ dbg.requested_model|default(dbg.meta.model|default('—')) }}</td>
                      <td><span class="badge bg-secondary-lt">{{ dbg.image_source|default('—') }}</span></td>
                      <td class="text-end">{{ r._tokens.total|default(0) }}</td>
                    </tr>
                  {% else %}
                    <tr><td colspan="4" class="text-muted small">No task executions recorded.</td></tr>
                  {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <div class="card">
            <div class="card-header"><h4 class="card-title mb-0">Try Better Passes</h4></div>
            <div class="card-body d-flex flex-wrap gap-2">
              <a class="btn btn-sm btn-outline-primary" href="{{ path('asset_run_task', {id: asset.id, taskName: 'enrich_from_thumbnail'}) ~ '?image=full&async=1' }}">Re-run enrich_from_thumbnail (full-res)</a>
              <a class="btn btn-sm btn-outline-primary" href="{{ path('asset_run_task', {id: asset.id, taskName: 'context_description'}) ~ '?image=full&model=mistral-large-latest&async=1' }}">context_description (full-res, mistral hint)</a>
              <a class="btn btn-sm btn-outline-primary" href="{{ path('asset_run_task', {id: asset.id, taskName: 'ocr_mistral'}) ~ '?image=full&async=1' }}">ocr_mistral (full-res)</a>
              <div class="w-100 small text-muted mt-1">Model/image preferences are recorded in debug metadata; model hints depend on handler support.</div>
            </div>
          </div>
        </div>

        {# ── Tasks ────────────────────────────────────────────────────────────── #}
        <div id="{{ tabId }}-tasks" class="tab-pane" role="tabpanel">
          <div class="card mb-3">
            <div class="card-header"><h4 class="card-title">Pipelines</h4></div>
            <div class="card-body d-flex gap-2 flex-wrap">
              {% for pipelineName, pipelineTasks in pipelines %}
                <form method="post" action="{{ path('asset_enqueue_pipeline', {id: asset.id, name: pipelineName}) }}">
                  <button class="btn btn-sm btn-outline-primary">
                    ▶ {{ pipelineName|capitalize }} pipeline
                    <span class="badge bg-primary-lt ms-1">{{ pipelineTasks|length }}</span>
                  </button>
                </form>
              {% endfor %}
              <a href="{{ path('asset_task_registry') }}" class="btn btn-sm btn-ghost-secondary">View task registry →</a>
            </div>
            {% if asset.aiQueue|length > 0 %}
              <div class="card-footer small text-muted">Queue: {{ asset.aiQueue|join(' → ') }}</div>
            {% endif %}
          </div>
          <div class="card mb-0">
            <div class="card-header">
              <h4 class="card-title">Run Individual Task</h4>
              <div class="card-options text-muted small">results appear in AI Task Results tab</div>
            </div>
            <div class="card-body">
              <div class="row g-2" id="task-grid" hx-sync="this:queue sequential">
                {% for task in tasks %}
                  {% set isDone = completedMap[task] is defined %}
                  {% set hasFailed = isDone and (completedMap[task].result.failed is defined) %}
                  {% set meta = taskMeta[task] ?? {} %}
                  {% set entry = completedMap[task]|default(null) %}
                  {% set debug = entry and entry.result._debug is defined ? entry.result._debug : null %}
                  {% set promptCombined = debug and debug.prompt is defined and debug.prompt.combined is defined ? debug.prompt.combined : null %}
                  {% set imageUrl = debug and debug.image_url is defined ? debug.image_url : null %}
                  {% set popContent %}agent: {{ meta.agent|default('?') }}
model: {{ meta.model|default('—') }}
platform: {{ meta.platform|default('—') }}{% if imageUrl %}

image_url: {{ imageUrl }}{% endif %}
{% if promptCombined %}

prompt:
{{ promptCombined }}
{% else %}

{{ meta.system_prompt|default('no prompt info')|slice(0, 600) }}{% if (meta.system_prompt|default(''))|length > 600 %}…{% endif %}
{% endif %}{% endset %}
                  <div class="col-sm-6" id="task-card-col-{{ task }}">
                    {{ include('asset/_task_card.html.twig', {
                      task: task, isDone: isDone, hasFailed: hasFailed,
                      entry: entry, meta: meta, popContent: popContent,
                      assetId: asset.id,
                    }, with_context: false) }}
                  </div>
                {% endfor %}
              </div>
            </div>
          </div>
        </div>

        {# ── Dev Dump (debug only) ─────────────────────────────────────────────── #}
        {% if app.debug %}
        <div id="{{ tabId }}-dev_dump" class="tab-pane" role="tabpanel">
          <details open>
            <summary class="small text-muted mb-2">asset dump (dev only)</summary>
            {% guard function dump %}{{ dump(asset) }}{% endguard %}
          </details>
        </div>
        {% endif %}

          </div>{# /tab-content #}
        </div>{# /card-body #}
      </div>{# /card #}

      <script>
      (function () {
        var nav = document.getElementById({{ (tabId ~ '-nav')|json_encode|raw }});
        if (!nav) return;
        var hash = location.hash.slice(1);
        if (hash) {
          var link = nav.querySelector('[data-tab-id="' + hash + '"]');
          if (link) { link.click(); }
        }
        nav.addEventListener('shown.bs.tab', function (e) {
          var id = e.target.getAttribute('data-tab-id');
          if (id) history.replaceState(null, '', '#' + id);
        });
      })();
      </script>


    </div>{# /col-lg-7 #}
  </div>{# /row #}
</div>
{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    /* HTMX request in flight: show spinner, hide the arrow label.
       htmx-request is added to the element with hx-post (the <form>),
       but with hx-sync on a parent HTMX 2 may add it to the grid div too.
       Cover both cases. */
    .htmx-indicator                          { display: none; }
    .htmx-request .htmx-indicator,
    .htmx-request.htmx-indicator             { display: inline-block !important; }
    .htmx-request .htmx-indicator-hide,
    .htmx-request.htmx-indicator-hide        { display: none !important; }
    .htmx-request button                     { pointer-events: none; opacity: 0.75; }

    /* Hide the "no tasks run yet" placeholder once real entries exist */
    #task-log #log-empty:not(:only-child)    { display: none !important; }

    /* Task info popover — monospace prompt text, reasonable width */
    .task-popover .popover-body {
      font-family: var(--tblr-font-monospace, monospace);
      font-size: 0.72rem;
      white-space: pre-wrap;
      max-width: 360px;
      color: #333;
    }
    .popover { max-width: 380px; }

    .simple-zoom-wrap {
      width: 100%;
      min-height: 512px;
      max-height: 70vh;
      overflow: auto;
      background: #f5f7fb;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: zoom-in;
    }

    .simple-zoom-image {
      max-width: 100%;
      height: auto;
      transform-origin: center center;
      transition: transform 0.08s linear;
      user-select: none;
      -webkit-user-drag: none;
    }
  </style>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script type="module">
    import 'htmx.org';
    import { Popover } from 'bootstrap';

    document.querySelectorAll('[data-bs-toggle="popover"]').forEach(el => {
      new Popover(el, { html: false });
    });

    {% if not useIiif %}
    const simpleWrap = document.getElementById('simple-zoom-wrap');
    const simpleImage = document.getElementById('simple-zoom-image');

    if (simpleWrap && simpleImage) {
      let scale = 1;
      let fallbackTried = false;

      simpleImage.addEventListener('error', () => {
        if (fallbackTried) {
          return;
        }
        const fallback = simpleImage.dataset.fallbackSrc;
        if (fallback && fallback !== simpleImage.src) {
          fallbackTried = true;
          simpleImage.src = fallback;
        }
      });

      const applyScale = () => {
        simpleImage.style.transform = `scale(${scale})`;
      };

      simpleWrap.addEventListener('wheel', (event) => {
        event.preventDefault();
        const delta = event.deltaY < 0 ? 0.1 : -0.1;
        scale = Math.max(1, Math.min(8, scale + delta));
        applyScale();
      }, { passive: false });

      simpleWrap.addEventListener('dblclick', () => {
        scale = scale > 1 ? 1 : 2;
        applyScale();
      });
    }
    {% endif %}
  </script>
{% endblock %}
