{% extends 'base.html.twig' %}

{% block title %}Search Assets{% endblock %}

{% block body %}
    <div class="container-xl py-4">
        <div class="page-header mb-3">
            <div class="row align-items-center">
                <div class="col">
                    <h2 class="page-title">Search Assets</h2>
                    <div class="text-muted">Doctrine-backed search. Meilisearch is not required for this page.</div>
                </div>
                <div class="col-auto ms-auto">
                    <a href="{{ path('asset_browse') }}" class="btn btn-outline-secondary">Browse Assets</a>
                </div>
            </div>
        </div>

        <twig:Mezcalito:UxSearch:Layout name="asset"/>
    </div>
{% endblock %}
