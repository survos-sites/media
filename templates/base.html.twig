{% extends app.request.headers.get('_page_content_only', app.request.query.get('_page_content_only'))
    ? "content_only.html.twig":
    "layout.html.twig"
%}

{% block content %}
    {% if block('body') is defined %}
        {{ block('body') }}
    {% endif %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
{% endblock %}

    {% block stylesheets %}
        {{ parent() }}
    {% endblock %}
