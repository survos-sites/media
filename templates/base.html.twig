{% extends app.request.headers.get('_page_content_only', app.request.query.get('_page_content_only'))
    ? "@SurvosBootstrap/_content_only.html.twig":
    "layout.html.twig"
%}

    {% block javascripts %}
        {{ parent() }}
        {{ importmap('app') }}
        <script src="https://cdn.jsdelivr.net/npm/openseadragon@6.0.1/build/openseadragon/openseadragon.min.js"></script>
        <script src="https://unpkg.com/mirador/dist/mirador.min.js"></script>
    {% endblock %}

    {% block stylesheets %}
        {# @todo: switch to easyadmin #}
        <link rel="stylesheet" type="text/css" href="{{ asset('bundles/survosbootstrap/bootstrap/style.css') }}">
        {{ parent() }}
    {% endblock %}


