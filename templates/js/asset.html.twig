{% set cfg = {
    pk: _config.primaryKey | default('id')
} %}

{% set pkVal = attribute(hit, cfg.pk) is defined ? attribute(hit, cfg.pk) : (hit.id ?? null) %}
{% set modalController = globals._sc_modal|default(_sc_modal|default('@survos/meili-bundle/json')) %}

{% set sourceMeta = attribute(hit, 'sourceMeta')|default({}) %}
{% set title = hit.aiTitle|default(hit.title|default(attribute(sourceMeta, 'dcterms:title')|default('Untitled record'))) %}
{% set description = hit.aiDescription|default(hit.description|default(attribute(sourceMeta, 'dcterms:description')|default(''))) %}

{% set thumb =
    hit.smallUrl
    |default(hit.thumbnail_url)
    |default(hit.thumbnail)
    |default(attribute(sourceMeta, 'thumbnail_url'))
    |default(hit.archiveUrl)
    |default(hit.originalUrl)
    |default(null)
%}

{% set ark = attribute(sourceMeta, 'source_ark')|default(null) %}
{% set sourceUrl =
    attribute(sourceMeta, 'dcterms:source')
    |default(attribute(sourceMeta, 'iiif_manifest'))
    |default(hit.originalUrl)
    |default(null)
%}

<article class="card h-100 border-0 shadow-sm overflow-hidden">
  {% if thumb %}
    <div class="ratio" style="--tblr-aspect-ratio: 62.5%; background: #eef3f7;">
      <img

        src="{{ thumb }}"
        alt="{{ title }}"
        loading="lazy"
        decoding="async"
        style="max-height:200px;max-width:200px;width:100%;height:100%;object-fit:cover;"
      >
    </div>
  {% endif %}

  <div class="card-body d-flex flex-column gap-2">
    <div>
      <h3 class="h5 mb-1" style="line-height:1.25;">{{ title }}</h3>
      {% if attribute(sourceMeta, 'dcterms:publisher') is defined and attribute(sourceMeta, 'dcterms:publisher') %}
        <div class="text-muted small">{{ attribute(sourceMeta, 'dcterms:publisher') }}</div>
      {% endif %}
    </div>

    <div class="d-flex flex-wrap gap-1">
      {% if hit.marking ?? false %}<span class="badge bg-blue-lt">{{ hit.marking }}</span>{% endif %}
      {% if hit.mime ?? false %}<span class="badge bg-secondary-lt">{{ hit.mime }}</span>{% endif %}
      {% if hit.aiDocumentType ?? false %}<span class="badge bg-teal-lt">{{ hit.aiDocumentType }}</span>{% endif %}
      {% if attribute(sourceMeta, 'dcterms:date') is defined and attribute(sourceMeta, 'dcterms:date') %}
        <span class="badge bg-amber-lt">{{ attribute(sourceMeta, 'dcterms:date') }}</span>
      {% endif %}
    </div>

    {% if description %}
      <p class="text-muted mb-0" style="display:-webkit-box;-webkit-line-clamp:4;-webkit-box-orient:vertical;overflow:hidden;">
        {{ description }}
      </p>
    {% endif %}
  </div>

  <div class="card-footer bg-transparent border-0 d-flex flex-wrap gap-2 justify-content-between align-items-center">
    <div class="d-flex flex-wrap gap-2 align-items-center">
      {% if pkVal %}
        <button
          type="button"
          {{ stimulus_action(modalController, 'modal') }}
          data-hit-id="{{ pkVal }}"
          class="btn btn-sm btn-primary"
          title="View JSON details"
        >
          {{ ux_icon('json')|raw }}
          <span class="ms-1">JSON</span>
        </button>
      {% endif %}

      {% if pkVal %}
        <a href="/media/{{ pkVal }}" class="btn btn-sm btn-outline-primary">Record</a>
      {% endif %}
    </div>

    <div class="d-flex flex-wrap gap-2 align-items-center">
      {% if sourceUrl %}
        <a href="{{ sourceUrl }}" target="_blank" rel="noreferrer" class="btn btn-sm btn-outline-secondary">Source</a>
      {% endif %}
      {% if ark %}
        <a href="https://ark.digitalcommonwealth.org/ark:/50959/{{ ark }}" target="_blank" rel="noreferrer" class="btn btn-sm btn-outline-secondary">ARK</a>
      {% endif %}
    </div>
  </div>
</article>
