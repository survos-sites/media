###> survos/media-bundle ###
IMGPROXY_KEY=
IMGPROXY_SALT=
###< survos/media-bundle ###

# most of the time we use flysystem, but sometimes we need direct access
APP_DATA_DIR=./shared

# Tesseract OCR microservice endpoint. Leave empty to disable OCR.
OCR_HOST=https://tesseract.survos.com/tesseract
SERVICE_MIN_INTERVAL_MS=1000
SERVICE_HTTP_TIMEOUT_SECONDS=120
SERVICE_529_COOLDOWN_MS=1000

